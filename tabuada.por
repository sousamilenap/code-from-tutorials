programa {
  funcao inicio() {
    inteiro tabuada 
    inteiro contador

      escreva("Qual tabuada você quer calcular?")
      leia(tabuada)
    
    para(contador=1;contador<=10;contador++){
      escreva(tabuada, " x ", contador, " = ", tabuada*contador)
      escreva("\n")

    }

    }
   
  }
}
